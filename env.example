# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Production Environment Settings
NODE_ENV=development
PORT=3000
JWT_SECRET=replace-with-a-long-random-production-secret

# Comma-separated list of "root" superadmin emails. These accounts can reset
# the password of any other superadmin (normally superadmins cannot reset
# each other's passwords). Previously this was hardcoded in src/api/users.ts -
# now it lives here so it never gets committed to git and can differ per environment.
ROOT_ADMIN_EMAILS=enkhtur.a@mobicom.mn,Enkhtur040607@gmail.com

# Initial/seed superadmin credentials. Use strong, private values in real environments.
INITIAL_SUPERADMIN_EMAIL=admin@example.com
INITIAL_SUPERADMIN_PASSWORD=replace-with-strong-password
SEED_SUPERADMIN_EMAIL=admin@example.com
SEED_SUPERADMIN_PASSWORD=replace-with-strong-password

# Local development uses database.sqlite.
# Production currently uses Azure SQL / Microsoft SQL Server.
DB_SERVER=your-sql-server.database.windows.net
DB_NAME=contact_center
DB_USER=sql_user
DB_PASSWORD=sql_password
DB_PORT=1433

# Public frontend URL used in password setup links.
# Example: https://contact-center-app.azurewebsites.net
APP_PUBLIC_URL=https://your-app.azurewebsites.net

# Password setup email delivery.
# This app sends emails through a secure HTTP webhook (Azure Logic App, Power Automate,
# Azure Function, SendGrid webhook proxy, etc.). The webhook must accept JSON:
# { "to", "subject", "text", "html" }
EMAIL_INVITE_WEBHOOK_URL=https://your-email-webhook-url
EMAIL_WEBHOOK_SECRET=optional-shared-secret
PASSWORD_SETUP_TOKEN_TTL_HOURS=24
